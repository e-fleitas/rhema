# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ─── RHEMA — EXCLUSIONES ESPECÍFICAS DEL PROYECTO ────────────────────────────

# Modelos de voz Piper (.onnx + archivos de configuración .json)
# Son archivos de 50-150 MB. Cada usuario los descarga por separado.
# Ver: scripts/download_models.sh (pendiente de crear)
assets/models/
*.onnx
*.onnx.json

# Bases de datos SQLite generadas durante desarrollo y pruebas.
# Nunca versionar datos de usuario, ni siquiera de prueba.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Código autogenerado por drift + build_runner.
# Se regenera con: flutter pub run build_runner build
# No se versiona porque puede reconstruirse desde el esquema fuente.
*.g.dart
*.drift.dart

# Archivos de Bibles importados por el usuario durante pruebas locales.
# (el desarrollador puede importar Biblias .json para probar,
# pero esos archivos no pertenecen al repositorio)
assets/bibles/*.json
assets/bibles/*.sqlite

# Mantener los placeholders que sí queremos en Git
!assets/bibles/.gitkeep
!assets/fonts/.gitkeep

# ─── ENTORNO LOCAL ────────────────────────────────────────────────────────────

# Variables de entorno locales (si en el futuro usamos flutter_dotenv)
.env
.env.local
.env.*.local

# Configuración personal de VSCode (sí versionar la carpeta .vscode/
# con configuraciones del proyecto, pero no las preferencias personales)
.vscode/settings.json
.vscode/launch.json